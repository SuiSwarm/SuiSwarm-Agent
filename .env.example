# ---------------------------------------------------------------------------
# SuiSwarm Agent configuration
#
# Two styles are supported:
#   * conventional names for secrets (OPENAI_API_KEY, TAVILY_API_KEY, ...)
#   * nested names for structured config (LLM__MODEL, HTTP__TIMEOUT, ...)
# Copy to .env and fill in. Only OPENAI_API_KEY is strictly required.
# ---------------------------------------------------------------------------

# --- LLM (required) --------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
# LLM__PROVIDER=openai
# LLM__MODEL=gpt-4o-mini
# LLM__BASE_URL=                 # for Azure / OpenAI-compatible / local endpoints
# LLM__TEMPERATURE_WORKER=0.2

# --- Market data (optional; enables the market sub-agent) ------------------
COINGECKO_DEMO_API_KEY=your_coingecko_demo_api_key_here

# --- Web research (optional; enables the research sub-agent) ---------------
TAVILY_API_KEY=your_tavily_api_key_here

# --- Sui service (optional; enables the Sui sub-agent — see docs, Phase 8) --
# All Sui interaction is delegated to an external NestJS service over REST.
# SUI_SERVICE__BASE_URL=http://localhost:3000
# SUI_SERVICE__API_KEY=your_sui_service_api_key
# SUI_SERVICE__API_KEY_HEADER=x-api-key

# --- Observability (optional) ----------------------------------------------
# LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
# LANGFUSE_SECRET_KEY=your_langfuse_secret_key
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- HTTP client tuning (optional) -----------------------------------------
# HTTP__TIMEOUT=20
# HTTP__MAX_RETRIES=3
# HTTP__RATE_LIMIT_PER_MINUTE=30

# --- Persistence (optional) ------------------------------------------------
# PERSISTENCE__BACKEND=memory          # memory | sqlite | postgres
# PERSISTENCE__SQLITE_PATH=./.suiswarm/checkpoints.sqlite
# PERSISTENCE__POSTGRES_DSN=postgresql://user:pass@localhost:5432/suiswarm

# --- Agent / server (optional) ---------------------------------------------
# AGENT__ENABLED_AGENTS=["market","research"]
# AGENT__RECURSION_LIMIT=40
# SERVER__PORT=8000
